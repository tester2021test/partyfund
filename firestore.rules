rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isPartyAdmin(partyId) {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/parties/$(partyId)).data.adminId == request.auth.uid;
    }
    
    // Parties Collection
    match /parties/{partyId} {
      // Anyone authenticated can read parties
      allow read: if isAuthenticated();
      
      // Only authenticated users can create parties
      // They must set themselves as admin
      allow create: if isAuthenticated() && 
                       request.resource.data.adminId == request.auth.uid;
      
      // Only the admin can update/delete their party
      allow update, delete: if isPartyAdmin(partyId);
    }
    
    // Members Collection
    match /members/{memberId} {
      // Anyone authenticated can read members
      allow read: if isAuthenticated();
      
      // Only party admin can create/update/delete members
      allow create: if isAuthenticated() && 
                       isPartyAdmin(request.resource.data.partyId);
      
      allow update, delete: if isAuthenticated() && 
                               isPartyAdmin(resource.data.partyId);
    }
    
    // Transactions Collection
    match /transactions/{transactionId} {
      // Anyone authenticated can read transactions
      allow read: if isAuthenticated();
      
      // Only party admin can create/update/delete transactions
      allow create: if isAuthenticated() && 
                       isPartyAdmin(request.resource.data.partyId);
      
      allow update, delete: if isAuthenticated() && 
                               isPartyAdmin(resource.data.partyId);
    }
  }
}
